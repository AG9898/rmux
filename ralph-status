#!/usr/bin/env bash
# Show status of all running ralph instances

shopt -s nullglob

RALPH_DIR="$HOME/.ralph"
PID_DIR="$RALPH_DIR/pids"
LOG_DIR="$RALPH_DIR/logs"

meta_value() {
  local key="$1"
  local meta="$2"
  grep "^${key}=" "$meta" | head -n1 | cut -d= -f2-
}

meta_prompt() {
  local meta="$1"
  local prompt_b64
  prompt_b64="$(meta_value prompt_b64 "$meta")"
  if [ -n "$prompt_b64" ]; then
    printf '%s' "$prompt_b64" | base64 --decode 2>/dev/null || \
      printf '%s' "$prompt_b64" | base64 -d 2>/dev/null
  else
    meta_value prompt "$meta"
  fi
}

if [ ! -d "$PID_DIR" ]; then
  echo "No ralph instances have been started yet."
  exit 0
fi

case "${1:-list}" in
  list|ls)
    echo "── Active Ralphs ──"
    found=false
    for meta in "$PID_DIR"/*.meta; do
      [ -f "$meta" ] || continue
      name=$(meta_value name "$meta")
      pid=$(meta_value pid "$meta")
      prompt=$(meta_prompt "$meta")
      model=$(meta_value model "$meta")
      started=$(meta_value started "$meta")
      run=$(meta_value current_run "$meta")
      max=$(meta_value max_runs "$meta")
      work_dir=$(meta_value work_dir "$meta")

      if kill -0 "$pid" 2>/dev/null; then
        status="🟢 running"
      else
        status="🔴 dead"
      fi

      found=true
      echo ""
      echo "  $name  ($status, PID $pid)"
      echo "    Model:   $model"
      echo "    Dir:     $work_dir"
      echo "    Prompt:  ${prompt:0:80}$([ ${#prompt} -gt 80 ] && echo '...')"
      echo "    Run:     ${run:-?}$([ "$max" != "0" ] && echo "/$max")"
      echo "    Started: $started"
    done

    if [ "$found" = false ]; then
      echo "  No ralph instances found."
    fi
    ;;

  tail)
    name="$2"
    if [ -z "$name" ]; then
      # Tail the most recent log
      logs=("$LOG_DIR"/*.log)
      if [ ${#logs[@]} -eq 0 ]; then
        echo "No logs found."
        exit 1
      fi
      log=$(ls -t "$LOG_DIR"/*.log | head -1)
    else
      log="$LOG_DIR/${name}.log"
    fi
    if [ -f "$log" ]; then
      echo "── Tailing $log ──"
      tail -n "${3:-50}" "$log"
    else
      echo "No log found${name:+ for '$name'}."
    fi
    ;;

  log)
    name="$2"
    if [ -z "$name" ]; then
      logs=("$LOG_DIR"/*.log)
      if [ ${#logs[@]} -eq 0 ]; then
        echo "No logs found."
        exit 1
      fi
      log=$(ls -t "$LOG_DIR"/*.log | head -1)
    else
      log="$LOG_DIR/${name}.log"
    fi
    if [ -f "$log" ]; then
      echo "$log"
    else
      echo "No log found${name:+ for '$name'}."
      exit 1
    fi
    ;;

  logs)
    echo "── Ralph Logs ──"
    logs=("$LOG_DIR"/*.log)
    if [ ${#logs[@]} -eq 0 ]; then
      echo "  No logs found."
    else
      ls -lht "$LOG_DIR"/*.log
    fi
    ;;

  kill)
    name="$2"
    if [ -z "$name" ]; then
      echo "Usage: ralph-status kill <name|all>"
      exit 1
    fi
    if [ "$name" = "all" ]; then
      for meta in "$PID_DIR"/*.meta; do
        [ -f "$meta" ] || continue
        pid=$(grep '^pid=' "$meta" | cut -d= -f2-)
        n=$(grep '^name=' "$meta" | cut -d= -f2-)
        if kill -0 "$pid" 2>/dev/null; then
          # Kill entire process group (children, grandchildren, etc.)
          kill -- -"$pid" 2>/dev/null
          kill "$pid" 2>/dev/null
          pkill -TERM -P "$pid" 2>/dev/null
          echo "Killed $n (PID $pid + children)"
        else
          echo "Already dead: $n (PID $pid)"
        fi
        rm -f "$meta" "$PID_DIR/${n}.pid"
      done
    else
      meta="$PID_DIR/${name}.meta"
      if [ -f "$meta" ]; then
        pid=$(grep '^pid=' "$meta" | cut -d= -f2-)
        if kill -0 "$pid" 2>/dev/null; then
          kill -- -"$pid" 2>/dev/null
          kill "$pid" 2>/dev/null
          pkill -TERM -P "$pid" 2>/dev/null
          echo "Killed $name (PID $pid + children)"
        else
          echo "$name not running"
        fi
        rm -f "$meta" "$PID_DIR/${name}.pid"
      else
        echo "No ralph named '$name' found."
      fi
    fi
    ;;

  restart)
    name="$2"
    new_runs="${3:-0}"
    if [ -z "$name" ]; then
      echo "Usage: ralph-status restart <name> [max_runs]"
      echo "  Restart a dead ralph with the same prompt/dir/model but a new run limit."
      echo "  max_runs defaults to 0 (unlimited)."
      exit 1
    fi

    meta="$PID_DIR/${name}.meta"
    if [ ! -f "$meta" ]; then
      echo "No ralph named '$name' found."
      exit 1
    fi

    pid=$(grep '^pid=' "$meta" | cut -d= -f2-)
    if kill -0 "$pid" 2>/dev/null; then
      echo "$name is still running (PID $pid). Kill it first or wait for it to finish."
      exit 1
    fi

    # Read settings from the dead ralph's metadata
    prompt=$(meta_prompt "$meta")
    model=$(meta_value model "$meta")
    work_dir=$(meta_value work_dir "$meta")
    marathon=$(meta_value marathon "$meta")
    enforce_taskq_cycle=$(meta_value enforce_taskq_cycle "$meta")

    # Clean up old metadata
    rm -f "$meta" "$PID_DIR/${name}.pid"

    # Build the ralph command
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    ralph_cmd=("$SCRIPT_DIR/ralph")
    ralph_cmd+=("$prompt")
    [ "$new_runs" != "0" ] && ralph_cmd+=("$new_runs")
    ralph_cmd+=(-n "$name" -m "$model" -d "$work_dir")
    [ "$marathon" = "true" ] && ralph_cmd+=(--marathon)
    [ "$enforce_taskq_cycle" = "true" ] && ralph_cmd+=(--enforce-taskq-cycle)
    [ "$enforce_taskq_cycle" = "false" ] && ralph_cmd+=(--no-enforce-taskq-cycle)

    echo "Restarting $name..."
    echo "  Model:    $model"
    echo "  Dir:      $work_dir"
    echo "  Runs:     $([ "$new_runs" = "0" ] && echo "unlimited" || echo "$new_runs")"
    echo "  Prompt:   ${prompt:0:80}$([ ${#prompt} -gt 80 ] && echo '...')"

    # Spawn detached
    nohup "${ralph_cmd[@]}" </dev/null &>/dev/null &
    disown
    sleep 1

    # Verify it started
    if [ -f "$PID_DIR/${name}.meta" ]; then
      new_pid=$(grep '^pid=' "$PID_DIR/${name}.meta" | cut -d= -f2-)
      echo "  ✅ Restarted as PID $new_pid"
    else
      echo "  ⚠️  Failed to restart. Check logs."
    fi
    ;;

  clean)
    echo "Cleaning dead ralph metadata..."
    for meta in "$PID_DIR"/*.meta; do
      [ -f "$meta" ] || continue
      pid=$(grep '^pid=' "$meta" | cut -d= -f2-)
      name=$(grep '^name=' "$meta" | cut -d= -f2-)
      if ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$meta" "$PID_DIR/${name}.pid"
        echo "  Cleaned: $name"
      fi
    done
    ;;

  *)
    cat <<'USAGE'
Usage: ralph-status <command> [args]

Commands:
  list              Show all ralph instances and their status (default)
  tail [name] [n]   Show last n lines of a ralph's log (default: most recent, 50 lines)
  log [name]        Print log file path (for piping)
  logs              List all log files
  kill <name|all>   Kill a ralph instance (or all)
  restart <name> [max_runs]  Restart a dead ralph with same settings, new run limit
  clean             Remove metadata for dead instances
USAGE
    ;;
esac
